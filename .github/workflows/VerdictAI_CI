name: VerdictAI — CI Eval Gate


on:
  push:
    branches:
      - main
      - master
    paths-ignore:
      - "**.md"
      - ".gitignore"
      - "docs/**"
  pull_request:
    branches:
      - main
      - master
  workflow_dispatch:
    inputs:
      suite:
        description: "Single suite to run (leave blank to run all)"
        required: false
        default: ""

jobs:
  eval:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Cache pip dependencies
        uses: actions/cache@v4
        with:
          path: ~/.cache/pip
          key: ${{ runner.os }}-pip-${{ hashFiles('requirements.txt') }}
          restore-keys: |
            ${{ runner.os }}-pip-

      - name: Install dependencies
        run: pip install -r requirements.txt

      - name: Create config.env from secrets
        run: |
          echo "GROQ_API_KEY=${{ secrets.GROQ_API_KEY }}"           >> config.env
          echo "GROQ_MODEL=${{ secrets.GROQ_MODEL }}"               >> config.env
          echo "CEREBRAS_API_KEY=${{ secrets.CEREBRAS_API_KEY }}"   >> config.env
          echo "CEREBRAS_MODEL=${{ secrets.CEREBRAS_MODEL }}"       >> config.env
          echo "SAMBANOVA_API_KEY=${{ secrets.SAMBANOVA_API_KEY }}" >> config.env
          echo "SAMBANOVA_MODEL=${{ secrets.SAMBANOVA_MODEL }}"     >> config.env
          echo "JIRA_URL=${{ secrets.JIRA_URL }}"                   >> config.env
          echo "JIRA_EMAIL=${{ secrets.JIRA_EMAIL }}"               >> config.env
          echo "JIRA_API_TOKEN=${{ secrets.JIRA_API_TOKEN }}"       >> config.env
          echo "JIRA_PROJECT_KEY=${{ secrets.JIRA_PROJECT_KEY }}"   >> config.env
          echo "JIRA_ISSUE_TYPE=${{ secrets.JIRA_ISSUE_TYPE }}"     >> config.env
          echo "GITHUB_TOKEN=${{ secrets.GH_PAT }}"                 >> config.env
          echo "GITHUB_REPO=${{ secrets.VERDICTAI_REPO }}"          >> config.env
          echo "LANGCHAIN_TRACING_V2=false"                         >> config.env

      - name: Reset database
        run: python reset_db.py

      # ── Run specific suite (workflow_dispatch with input) ──────────────
      - name: Run single suite (manual trigger)
        if: ${{ github.event_name == 'workflow_dispatch' && github.event.inputs.suite != '' }}
        run: python -m runner.main --suite "${{ github.event.inputs.suite }}"

      # ── Run all suites on push / PR ────────────────────────────────────
      - name: Run hallucination suite
        if: ${{ github.event_name != 'workflow_dispatch' || github.event.inputs.suite == '' }}
        run: python -m runner.main --suite tests/suites/hallucination.yaml

      - name: Run safety suite
        if: ${{ github.event_name != 'workflow_dispatch' || github.event.inputs.suite == '' }}
        run: python -m runner.main --suite tests/suites/safety.yaml

      - name: Run format suite
        if: ${{ github.event_name != 'workflow_dispatch' || github.event.inputs.suite == '' }}
        run: python -m runner.main --suite tests/suites/format.yaml

      - name: Run RAG suite
        if: ${{ github.event_name != 'workflow_dispatch' || github.event.inputs.suite == '' }}
        run: python -m runner.main --suite tests/suites/rag.yaml

      # ── Upload artifacts ───────────────────────────────────────────────
      - name: Upload eval databases
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: verdictai-dbs-${{ github.run_number }}
          path: |
            verdictai.db
            memory/sentinel.db
          retention-days: 30

      - name: Upload logs
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: verdictai-logs-${{ github.run_number }}
          path: logs/
          retention-days: 14
